# Discord bot – copy to .env. Never commit .env.
#
# Required (secrets)
# -----------------
DISCORD_BOT_TOKEN=           # Bot token from Discord Developer Portal

# Supabase (replaces Fastify API + x-bot-secret)
# ------------------------------------------------
SUPABASE_URL=                # https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=   # service_role key (bypasses RLS — keep secret)

# Optional: legacy bot secret (kept for Edge Function auth validation)
# DISCORD_BOT_API_SECRET=

# Optional overrides (defaults in src/config.ts)
# ----------------------------------------------
# DISCORD_APPLICATION_ID=
# API_READINESS_MAX_WAIT_MS=30000
# API_READINESS_POLL_MS=1000
# VERIFY_URL_TEMPLATE=https://{{slug}}.dguild.org/verify?token={{token}}
# For local dev (verify lives on tenant app, port 3002):
# VERIFY_URL_TEMPLATE=http://localhost:3002/verify?token={{token}}
# DISCORD_ROLE_SYNC_INTERVAL_MS=900000
