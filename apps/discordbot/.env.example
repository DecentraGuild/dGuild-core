# Discord bot – copy to .env. Never commit .env.
#
# Required (secrets)
# -----------------
DISCORD_BOT_TOKEN=           # Bot token from Discord Developer Portal

# Supabase (PostgREST + Edge Functions) — required at container runtime on Railway
# ------------------------------------------------------------------------------
SUPABASE_URL=                # https://<project-ref>.supabase.co
# Service role JWT (Settings → API → service_role). Use this name OR SUPABASE_SERVICE_KEY below.
SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_SERVICE_KEY=      # same JWT; some Railway/Supabase templates only define this name

# Optional overrides (defaults in src/config.ts)
# ----------------------------------------------
# DISCORD_APPLICATION_ID=
# API_READINESS_MAX_WAIT_MS=30000
# API_READINESS_POLL_MS=1000
# VERIFY_URL_TEMPLATE=https://{{slug}}.dguild.org/verify?token={{token}}
# For local dev (verify lives on tenant app, port 3002):
# VERIFY_URL_TEMPLATE=http://localhost:3002/verify?token={{token}}
# Optional: force role sync cadence in ms (overrides public.interval_timers.discord_role_sync).
# DISCORD_ROLE_SYNC_INTERVAL_MS=900000
