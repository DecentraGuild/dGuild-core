# Platform app – copy to .env. Never commit .env.
#
# Required for Supabase (backend)
# ------------------------------
NUXT_PUBLIC_SUPABASE_URL=              # Local: http://localhost:65421 (match app host for cookies)  |  Prod: https://<project-ref>.supabase.co
NUXT_PUBLIC_SUPABASE_ANON_KEY=         # From supabase status (local) or Dashboard > Settings > API (prod)

# Optional overrides (defaults in nuxt.config.ts)
# ----------------------------------------------
# NUXT_PUBLIC_TENANT_BASE_DOMAIN=dguild.org
# NUXT_PUBLIC_HELIUS_RPC=...
