# Tenant app – copy to .env. Never commit .env.
#
# Required for marketplace (contains API key – keep secret)
# -------------------------------------------------------
# NUXT_PUBLIC_HELIUS_RPC=https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY

# Optional overrides (defaults in nuxt.config.ts: apiUrl, devTenantSlug, explorer URLs, etc.)
# ------------------------------------------------------------------------------------------
# NUXT_PUBLIC_API_URL=       # Production default: https://api.dguild.org
# NUXT_PUBLIC_DEV_TENANT=0000000   # or e.g. decentraguild for base tenant
# NUXT_PUBLIC_TENANT_SINGLE_HOST=dapp.dguild.org   # When on this host, no ?tenant= uses cached last tenant
