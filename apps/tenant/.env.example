# Tenant app – copy to .env. Never commit .env.
#
# Required for Supabase (backend)
# ------------------------------
NUXT_PUBLIC_SUPABASE_URL=              # Local API (Kong): http://localhost:65421 — NOT Studio (65423). Match localhost vs 127.0.0.1 with the app for cookies. Prod: https://<project-ref>.supabase.co
NUXT_PUBLIC_SUPABASE_ANON_KEY=        # From supabase status (local) or Dashboard > Settings > API (prod)

# Required for marketplace (Solana RPC – contains API key, keep secret)
# ---------------------------------------------------------------------
# NUXT_PUBLIC_HELIUS_RPC=https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY

# Optional overrides (defaults in nuxt.config.ts)
# ----------------------------------------------
# NUXT_PUBLIC_DEV_TENANT=0000000      # Default tenant on localhost without subdomain (use ?tenant=slug)
# NUXT_PUBLIC_INTERNAL_DEV_TENANT_IDS=  # Extra tenant ids (comma-separated) that may enable coming_soon / development modules; 0000000 is always included
# NUXT_PUBLIC_TENANT_SINGLE_HOST=dapp.dguild.org
# NUXT_PUBLIC_HELIUS_RPC=...

# Mobile wallet / MWA — set to canonical https origin (no trailing slash) for SIWS + ConnectorKit metadata
# (matches Supabase Auth redirect allow-list). When empty, SIWS uses the current browser URL.
# NUXT_PUBLIC_APP_URL=https://your-tenant-host.example
# WalletConnect QR (optional — get project id at https://cloud.walletconnect.com)
# NUXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Web3 sign-in (SIWS): Supabase Dashboard → Authentication → URL configuration → Redirect URLs must
# include globs so the signed URI matches. Example: URI in wallet is https://dapp.dguild.org/?tenant=...
# Add https://dapp.dguild.org/** and https://*.dguild.org/** (plain https://dapp.dguild.org is NOT enough).
