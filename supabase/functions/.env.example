# Edge Function secrets for local dev.
# Copy to supabase/functions/.env and fill in. Never commit .env.
# Auto-loaded by `supabase functions serve`. SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY
# are set automatically when running locally.
#
# Platform ops: wallet in platform_owner table (supabase/seed.sql). Update seed and run db reset.

# Required for billing, marketplace, whitelist, qualification (Generate JSON), etc.
HELIUS_RPC_URL=              # Solana RPC (e.g. https://mainnet.helius-rpc.com/?api-key=...)
WHITELIST_PROGRAM_ID=        # Default: WLSTEvb5PEG1HN6M5HAomdWQ6NyR7zFPwSVbzVJKHDZ
ESCROW_PROGRAM_ID=

# Optional
DISCORD_BOT_SECRET=
DISCORD_CLIENT_ID=
